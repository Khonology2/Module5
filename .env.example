# Flutter web build — point at your PDH Python API (OpenRouter keys live on the server only).
# Local dev default: http://127.0.0.1:8000 (run .\tool\start_backend.ps1 first).
# Production: set GitHub secret BACKEND_BASE_URL to your Render API URL, e.g. https://pdh-api.onrender.com
#
# BACKEND_BASE_URL is passed at build time:
#   flutter build web --dart-define=BACKEND_BASE_URL=https://your-api.onrender.com
#
# OpenRouter (backend/app/.env only — NOT needed in this file for AI):
#   OPENROUTER_API_KEY_PRIMARY=
#   OPENROUTER_API_KEY_SECONDARY=
#   OPENROUTER_MODEL=google/gemini-2.0-flash-001
