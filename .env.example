# OpenRouter (https://openrouter.ai/) — keys typically start with sk-or-v1-...
OPENROUTER_API_KEY_PRIMARY=
OPENROUTER_API_KEY_SECONDARY=
# Optional: model slug on OpenRouter, e.g. google/gemini-2.0-flash-001 or openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.0-flash-001
#
# Render / CI: Flutter web does not read .env on the server at runtime. Either:
# - Build with: flutter build web --dart-define=OPENROUTER_API_KEY_PRIMARY=... --dart-define=OPENROUTER_MODEL=...
# - Or set the same names as Environment variables in Render and pass them into your build command as --dart-define=...
# (main.dart merges String.fromEnvironment into dotenv when .env is missing).
