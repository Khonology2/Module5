    // Goal Daily Progress - owner can delete their own entries (used in goal deletion)
    match /goal_daily_progress/{progressId} {
      allow delete: if isSignedIn() && (
        userId() == resource.data.userId || 
        isManager() || 
        isAdmin()
      );
      allow read: if isSignedIn() && (
        userId() == resource.data.userId ||
        isManager() ||
        isAdmin()
      );
      allow create: if isSignedIn() && userId() == request.resource.data.userId;
      allow update: if false; // Prevent updates to maintain data integrity
    }
